adapters/

# Poisoned HuggingFace datasets (~4 MB).
# Regenerate via notebook 01 (and 22 for the generative-sleeper variants).
data/

# =============================================================================
# Internal / unpublished writing
# =============================================================================

# Paper drafts, handoff notes, audit findings. Excluded prior to arxiv release;
# README links to the published version once available.
paper/

# Internal project planning and researcher context.
project-knowledge.md

# Local scratch / utilities folder. Nothing in here is part of the published
# methodology; everything load-bearing lives in notebooks/.
scripts/

# Superseded notebooks. The Phase D v0.2 refactor on 2026-05-23 replaced these:
#   11 (early 7B cohort training)  -> 13 (canonical multi-seed 7B retrain)
#   12 (7B Phase A+B+C in one nb)  -> 13b + 14 + 15 (split per-phase, canonical
#                                    lowercase-b output paths)
# Omitted from the repo to avoid confusing readers. See README for full context.
notebooks/11_train_7B_cohort_v1.ipynb
notebooks/12_detect_7b_v1.ipynb

